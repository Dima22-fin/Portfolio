  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg: #f5f5f5;
      --bg-soft: #ececec;
      --panel: rgba(255, 255, 255, 0.88);
      --panel-strong: rgba(255, 255, 255, 0.96);
      --line: rgba(15, 23, 42, 0.10);
      --text: #18212f;
      --muted: #5f6b7c;
      --accent: #65d8ff;
      --accent-2: #7c5cff;
      --accent-3: #00ffa3;
      --shadow: 0 18px 45px rgba(15, 23, 42, 0.10);
      --radius: 22px;
      --max: 1180px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: var(--text);
      background: #f5f5f5;
      line-height: 1.6;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(24,33,47,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(24,33,47,0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      mask-image: linear-gradient(to bottom, rgba(24,33,47,0.14), transparent 85%);
      pointer-events: none;
      z-index: -1;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    .container {
      width: min(var(--max), calc(100% - 2rem));
      margin: 0 auto;
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(14px);
      background: rgba(255, 255, 255, 0.82);
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      min-height: 74px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: .9rem;
      font-weight: 800;
      letter-spacing: .02em;
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(101,216,255,0.18), rgba(124,92,255,0.3));
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.1), 0 10px 20px rgba(0,0,0,0.25);
      font-size: 0.95rem;
    }

    .nav-links {
      display: flex;
      gap: 1.2rem;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: .95rem;
    }

    .nav-links a:hover {
      color: var(--text);
    }

    .hero {
      padding: 4.5rem 0 2rem;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr .85fr;
      gap: 2rem;
      align-items: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: .55rem;
      padding: .5rem .85rem;
      border-radius: 999px;
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(15, 23, 42, 0.08);
      color: #4f5d70;
      font-size: .88rem;
      margin-bottom: 1.25rem;
    }

    .eyebrow::before {
      content: "";
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: linear-gradient(180deg, var(--accent), var(--accent-3));
      box-shadow: 0 0 18px rgba(101,216,255,0.8);
    }

    h1 {
      margin: 0;
      font-size: clamp(2.4rem, 5vw, 5rem);
      line-height: .98;
      letter-spacing: -.04em;
    }

    .gradient {
      background: linear-gradient(90deg, #ffffff 5%, #9be5ff 45%, #82a7ff 70%, #8f7bff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero p {
      color: var(--muted);
      font-size: 1.06rem;
      max-width: 720px;
      margin: 1.3rem 0 0;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 1.8rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .6rem;
      padding: .95rem 1.2rem;
      border-radius: 14px;
      font-weight: 600;
      border: 1px solid rgba(15, 23, 42, 0.10);
      transition: transform .2s ease, border-color .2s ease, background .2s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn-primary {
      background: linear-gradient(135deg, rgba(101,216,255,0.18), rgba(124,92,255,0.24));
      box-shadow: 0 18px 40px rgba(14, 21, 37, 0.6);
    }

    .btn-secondary {
      background: rgba(255,255,255,0.92);
      color: var(--text);
    }

    .hero-card {
      position: relative;
      padding: 1rem;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,250,252,0.96));
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 28px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .hero-card::after {
      content: "";
      position: absolute;
      inset: auto -20% -30% auto;
      width: 240px;
      height: 240px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(124,92,255,0.24), transparent 70%);
      filter: blur(20px);
      pointer-events: none;
    }

    .photo-wrap {
      position: relative;
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: #ffffff;
      aspect-ratio: 4 / 5;
    }

    .photo-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 20%;
      filter: saturate(1.02) contrast(1.04);
    }

    .floating-badge {
      position: absolute;
      left: 1rem;
      right: 1rem;
      bottom: 1rem;
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: .9rem 1rem;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 18px;
      backdrop-filter: blur(14px);
    }

    .floating-badge strong {
      display: block;
      font-size: .98rem;
    }

    .floating-badge span {
      color: var(--muted);
      font-size: .85rem;
    }

    /* .stats {
      margin-top: 1.8rem;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    } */

    .stat {
      padding: 1rem 1.1rem;
      background: rgba(255,255,255,0.9);
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 18px;
    }

    .stat strong {
      display: block;
      font-size: 1.25rem;
      margin-bottom: .25rem;
    }

    .stat span {
      color: var(--muted);
      font-size: .9rem;
    }

    section {
      padding: 2rem 0;
    }

    .section-title {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.4rem;
    }

    .section-title h2 {
      margin: 0;
      font-size: clamp(1.5rem, 3vw, 2.4rem);
      letter-spacing: -.03em;
    }

    .section-title p {
      margin: 0;
      color: var(--muted);
      max-width: 700px;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.3rem;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.3rem;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
    }

    .about-card {
      min-height: 100%;
    }

    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: .7rem;
      margin-top: 1rem;
    }

    .chip {
      padding: .6rem .85rem;
      border-radius: 999px;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(15, 23, 42, 0.08);
      color: #324154;
      font-size: .92rem;
    }

    .timeline {
      display: grid;
      gap: 1rem;
    }

    .timeline-item {
      position: relative;
      padding: 1.2rem 1.2rem 1.2rem 1.35rem;
      border-left: 2px solid rgba(101,216,255,0.3);
      background: rgba(248,250,252,0.95);
      border-radius: 0 18px 18px 0;
    }

    .timeline-item::before {
      content: "";
      position: absolute;
      left: -8px;
      top: 1.35rem;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: linear-gradient(180deg, var(--accent), var(--accent-2));
      box-shadow: 0 0 0 4px rgba(101,216,255,0.08);
    }

    .meta {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: .45rem;
    }

    .meta strong {
      font-size: 1.02rem;
    }

    .meta span {
      color: var(--muted);
      font-size: .93rem;
    }

    .timeline-item p {
      margin: 0;
      color: var(--muted);
      font-size: .96rem;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    .project {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      min-height: 100%;
      position: relative;
      overflow: hidden;
    }

    .project::after {
      content: "";
      position: absolute;
      inset: auto -60px -60px auto;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(101,216,255,0.12), transparent 70%);
      pointer-events: none;
    }

    .project-top {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 1rem;
    }

    .project-title {
      margin: 0;
      font-size: 1.1rem;
    }

    .project p {
      margin: 0;
      color: var(--muted);
      font-size: .95rem;
    }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: .55rem;
      margin-top: auto;
    }

    .tag {
      font-size: .82rem;
      color: #324154;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(15, 23, 42, 0.08);
      padding: .45rem .7rem;
      border-radius: 999px;
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .skill-col h3 {
      margin: 0 0 .8rem;
      font-size: 1rem;
    }

    .skill-list {
      display: grid;
      gap: .65rem;
      color: var(--muted);
      font-size: .95rem;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1.15fr .85fr;
      gap: 1rem;
    }

    .contact-list {
      display: grid;
      gap: .85rem;
      margin-top: 1rem;
    }

    .contact-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.05rem;
      border-radius: 16px;
      background: rgba(255,255,255,0.92);
      border: 1px solid rgba(15, 23, 42, 0.08);
    }

    .contact-item small {
      display: block;
      color: var(--muted);
      margin-bottom: .2rem;
    }

    footer {
      padding: 2rem 0 3rem;
      color: var(--muted);
      font-size: .92rem;
    }

    .footer-bar {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      padding-top: 1.4rem;
      border-top: 1px solid rgba(15, 23, 42, 0.08);
    }

    @media (max-width: 1100px) {
      .projects-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .skills-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      /* .stats {
        grid-template-columns: repeat(2, 1fr);
      } */
    }

    @media (max-width: 860px) {
      .hero-grid,
      .grid-2,
      .contact-grid,
      .projects-grid,
      .skills-grid {
        grid-template-columns: 1fr;
      }

      .nav-links {
        display: none;
      }

      .hero {
        padding-top: 2.7rem;
      }

      .section-title {
        align-items: start;
        flex-direction: column;
      }

      .floating-badge {
        position: static;
        margin-top: 1rem;
      }
    }

    @media (max-width: 560px) {
      .container {
        width: min(var(--max), calc(100% - 1rem));
      }

      .card,
      .hero-card {
        padding: 1rem;
      }

      /* .stats {
        grid-template-columns: 1fr;
      } */

      .hero-actions {
        flex-direction: column;
      }

      .btn {
        width: 100%;
      }
    }
  </style>
